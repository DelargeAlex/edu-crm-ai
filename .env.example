# Optional AI key for Flowise
OPENAI_API_KEY=

# LangSmith (observabilitet för LangChain-körningar i Flowise) — valfritt
# Skapa konto och API-nyckel på https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=bosses-akvariefiskar-demo
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# n8n -> Twenty
TWENTY_API_KEY=
CHATWOOT_API_ACCESS_TOKEN=

# React shop: Chatwoot website widget (valfritt, nåbart från webbläsaren)
VITE_CHATWOOT_BASE_URL=http://localhost:3001
VITE_CHATWOOT_WEBSITE_TOKEN=

# Flowise chatflow IDs used by n8n workflows
FLOWISE_CHATFLOW_ID=
FLOWISE_LEAD_CHATFLOW_ID=
FLOWISE_SUPPORT_CHATFLOW_ID=
FLOWISE_CHATWOOT_CHATFLOW_ID=

# Chatwoot infra
CHATWOOT_SECRET_KEY_BASE=change_me_with_long_random_value
CHATWOOT_POSTGRES_PASSWORD=chatwootpg
CHATWOOT_REDIS_PASSWORD=chatwootredis

# Twenty
TWENTY_POSTGRES_PASSWORD=twentypg
TWENTY_APP_SECRET=change_me_with_random_value
