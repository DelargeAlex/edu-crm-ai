        "inputAnchors": [],
        "inputs": {
          "template": "Du hjalper till i en enkel supportdemo for n8n Basic-serien.\\n\\nSvara med ENDAST giltig JSON utan markdown, exakt med dessa nycklar:\\n{\\n  \"category\": \"support | complaint | delivery | general_question\",\\n  \"reply\": \"kort svar pa svenska i max 4 meningar\",\\n  \"shouldEscalate\": false\\n}\\n\\nRegler:\\n- complaint anvands om kunden later missnojd eller beskriver fel/problem.\\n- delivery anvands om fragan handlar om leverans, saknad vara eller forsenad order.\\n- shouldEscalate ska vara true om fragan later arg, juridisk eller oklar.\\n\\nKundens fraga: {question}",
          "promptValues": "{\"question\":\"{{question}}\"}"
        },
        "outputAnchors": [
          {
            "id": "promptTemplate_0-output-promptTemplate-PromptTemplate|BaseStringPromptTemplate|BasePromptTemplate",
