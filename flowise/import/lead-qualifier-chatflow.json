        "label": "Prompt Template",
        "version": 1,
        "name": "promptTemplate",
        "type": "PromptTemplate",
        "baseClasses": ["PromptTemplate", "BaseStringPromptTemplate", "BasePromptTemplate"],
        "category": "Prompts",
        "description": "Schema to represent a basic prompt for an LLM",
        "inputParams": [
          {
            "label": "Template",
            "name": "template",
            "type": "string",
            "rows": 4,
            "placeholder": "What is a good name for a company that makes {product}?",
            "id": "promptTemplate_0-input-template-string"
          },
          {
            "label": "Format Prompt Values",
            "name": "promptValues",
            "type": "json",
            "optional": true,
            "acceptVariable": true,
            "list": true,
            "id": "promptTemplate_0-input-promptValues-json"
          }
        ],
        "inputAnchors": [],
        "inputs": {
          "template": "Du arbetar som leadkvalificerare för Bosses Akvariefiskar.\nBosses säljer döda akvariefiskar, Återupplivning Plus och Tidsmaskin Experience Pack.\n\nSvara med ENDAST giltig JSON utan markdown, exakt med dessa nycklar:\n{\n  \"leadType\": \"bulk_order | addon_question | time_machine_interest | resurrection_interest | complaint_reroute | press_or_partnership | unclear\",\n  \"customerType\": \"B2B | Privatkund | Oklart\",\n  \"productSuggestion\": \"kort produktnamn\",\n  \"priority\": \"high | medium | low\",\n  \"routeTo\": \"sales | support | partnerships\",\n  \"salesSummary\": \"max 2 meningar på svenska\",\n  \"funAngle\": \"kort rolig men användbar kommentar\"\n}\n\nRegler:\n- complaint_reroute används om meddelandet egentligen låter som support eller reklamation.\n- press_or_partnership används för journalistik, influencers, events, partnerskap eller white label.\n- bulk_order används vid offert, volymköp eller B2B-beställning.\n- productSuggestion ska vara en av: Zombie Guppy Deluxe, Återupplivning Plus, Tidsmaskin Experience Pack, Månadens Mystiskt Orörliga Fisk.\n\nKundens meddelande: {question}",
          "promptValues": "{\"question\":\"{{question}}\"}"
        },
        "outputAnchors": [
          {
            "id": "promptTemplate_0-output-promptTemplate-PromptTemplate|BaseStringPromptTemplate|BasePromptTemplate",
            "name": "promptTemplate",
            "label": "PromptTemplate",
            "type": "PromptTemplate | BaseStringPromptTemplate | BasePromptTemplate"
          }
        ],
        "outputs": {},
        "selected": false
      },
      "selected": false,
